---
import FontToggle from './FontToggle.astro'
import ThemeToggle from './ThemeToggle.astro'
---

<footer class="border-foreground text-muted-foreground flex flex-col gap-y-1 border-t py-2.5 text-sm">
  <div class="flex items-center justify-between">
    <p>&copy; {new Date().getFullYear()} Eli Heuer &middot; CC BY-SA 4.0</p>
    <div class="flex items-center gap-x-4">
      <FontToggle transition:persist />
      <ThemeToggle transition:persist />
    </div>
  </div>
</footer>
