---
// Standalone specimen page for Virtua Grotesk — full-page layout in the
// spirit of klim.co.nz font pages, inverted to light-gray-on-dark-gray.
// Deliberately does NOT use the site Layout: own <html>, own styles.
import glyphData from '@/data/virtua-grotesk-glyphs.json'

const weights = [
  { name: 'Regular', wght: 400 },
  { name: 'Medium', wght: 500 },
  { name: 'SemiBold', wght: 600 },
  { name: 'Bold', wght: 700 },
]

const details: [string, string][] = [
  ['Design', 'Eli Heuer'],
  ['Engineering', 'Eli Heuer, with Runebender, img2bez & designbot'],
  ['Released', '2026 · work in progress'],
  ['Version', '1.0'],
  ['Classification', 'Geometric grotesque'],
  ['Glyphs', '679 per style'],
  ['Styles', '4 instances · 1 variable font'],
  ['Formats', 'Variable TTF · Static TTF · WOFF2'],
  ['Scripts', 'Latin · Arabic (in progress)'],
  ['License', 'SIL Open Font License 1.1'],
]

const languages =
  'Afrikaans, Albanian, Basque, Bosnian, Breton, Catalan, Cornish, Croatian, ' +
  'Czech, Danish, Dutch, English, Esperanto, Estonian, Faroese, Filipino, ' +
  'Finnish, French, Frisian, Galician, German, Hungarian, Icelandic, ' +
  'Indonesian, Irish, Italian, Kurdish, Latvian, Lithuanian, Luxembourgish, ' +
  'Malay, Maltese, Manx, Māori, Norwegian, Polish, Portuguese, Romanian, ' +
  'Sámi, Scottish Gaelic, Serbian (Latin), Slovak, Slovenian, Spanish, ' +
  'Swahili, Swedish, Turkish, Welsh, Zulu — with Arabic-script support in ' +
  'progress for Arabic, Persian and Urdu.'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Virtua Grotesk</title>
    <meta
      name="description"
      content="Virtua Grotesk — a geometric grotesk with 16-unit chamfered corners, drawn on a powers-of-two grid. Variable weight 400–700. Free and open source under the SIL Open Font License 1.1."
    />
    <link rel="canonical" href="https://elih.net/virtua-grotesk" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <meta property="og:title" content="Virtua Grotesk" />
    <meta
      property="og:description"
      content="A geometric grotesk with 16-unit chamfered corners, drawn on a powers-of-two grid. Variable weight 400–700, free and open source."
    />
    <meta property="og:image" content="https://elih.net/og/virtua-grotesk.png" />
    <meta property="og:url" content="https://elih.net/virtua-grotesk" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body>
    <nav id="top">
      <span class="nav-title">Virtua Grotesk</span>
      <div class="nav-links">
        <a href="#information">Information</a>
        <a href="#styles">Styles</a>
        <a href="#tester">Tester</a>
        <a href="#features">Features</a>
        <a href="#glyphs">Glyphs</a>
        <a class="nav-button" href="https://github.com/eliheuer/virtua-grotesk">Download fonts</a>
      </div>
    </nav>

    <!-- Hero -->
    <header class="hero">
      <img
        src="/og/virtua-grotesk.png"
        alt="Virtua Grotesk dimension sheet: the word Grid drawn on the font's power-of-two grid"
      />
    </header>

    <!-- Information -->
    <section id="information">
      <h2 class="sec-label">Information</h2>
      <div class="sec-body">
        <div class="prose">
          <p>
            Virtua Grotesk is a geometric grotesk with 16-unit chamfered
            corners — every sharp junction gets a 45-degree bevel. Strokes are
            monolinear, with no thick–thin contrast; round forms use smooth
            curves with generous counters. The result is a retro-futurist
            technical character drawn with modern precision.
          </p>
          <p>
            Every measurement is a power of two or a short sum of them: 1024
            units per em, 768 cap height, 576 x-height, 16-unit chamfers on a
            2-unit grid. Weight gain across the axis works by counter
            reduction — outer contours often stay identical between Regular
            and Bold while the inner counter shrinks inward.
          </p>
          <p>
            Virtua Grotesk is also a machine-learning experiment: a typeface
            designed from the first point to be training data, and the demo
            font for an AI type-production pipeline. The full story is in the
            essay <a href="/blog/virtua-grotesk">Grid System as Dataset</a>. Sources,
            tooling and build system are open on
            <a href="https://github.com/eliheuer/virtua-grotesk">GitHub</a>.
          </p>
        </div>

        <dl class="details">
          {
            details.map(([k, v]) => (
              <div class="detail-row">
                <dt>{k}</dt>
                <dd>{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- Variable axes -->
    <section>
      <h2 class="sec-label">Variable Font Axes</h2>
      <div class="sec-body">
        <table class="mono-table">
          <thead>
            <tr><th>Axis</th><th>Tag</th><th>Min</th><th>Default</th><th>Max</th></tr>
          </thead>
          <tbody>
            <tr><td>Weight</td><td>wght</td><td>400</td><td>400</td><td>700</td></tr>
          </tbody>
        </table>
        <table class="mono-table" style="margin-top: 2rem;">
          <thead>
            <tr><th>Font</th><th>Format</th><th>Web file size</th></tr>
          </thead>
          <tbody>
            <tr><td>Virtua Grotesk Variable</td><td>WOFF2</td><td>34 kb</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Styles -->
    <section id="styles">
      <h2 class="sec-label">Styles</h2>
      <div class="style-list">
        {
          weights.map(({ name, wght }) => (
            <div class="style-row">
              <div class="style-meta">
                <span class="mono-label">{name} · {wght}</span>
                <input
                  type="range"
                  class="size-slider"
                  min="24"
                  max="160"
                  value="96"
                  aria-label={`Sample size for ${name}`}
                />
              </div>
              <div
                class="style-sample"
                contenteditable="true"
                spellcheck="false"
                style={`font-weight: ${wght}; font-size: 96px;`}
              >
                Virtua Grotesk {name}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Weight tester -->
    <section id="tester">
      <h2 class="sec-label">Variable Weight Tester</h2>
      <div class="sec-body">
        <div class="tester-controls">
          <label class="mono-label" for="wght-slider">wght</label>
          <input type="range" id="wght-slider" min="400" max="700" step="1" value="400" />
          <span class="mono-label" id="wght-value">400</span>
        </div>
        <div id="tester-text" contenteditable="true" spellcheck="false">
          Grid as dataset — 1024 units, 16-unit chamfers, powers of two.
        </div>
      </div>
    </section>

    <!-- OpenType features -->
    <section id="features">
      <h2 class="sec-label">OpenType Features</h2>
      <div class="sec-body">
        <div class="feature-row">
          <div class="feature-meta">
            <span class="mono-label">tnum</span>
            <p>Tabular figures. Every digit takes the same advance width, so
            columns of numbers align.</p>
            <label class="mono-label toggle">
              <input type="checkbox" id="tnum-toggle" /> apply tnum
            </label>
          </div>
          <div class="feature-demo" id="tnum-demo">
            0123456789<br />1463082957<br />2048102464
          </div>
        </div>

        <div class="feature-row">
          <div class="feature-meta">
            <span class="mono-label">init · medi · fina · rlig</span>
            <p>Arabic contextual shaping. Letters connect and change form by
            position; required ligatures are drawn as single glyphs.
            Outlines are in progress.</p>
          </div>
          <div class="feature-demo" dir="rtl" lang="ar">
            الحروف تتصل بسلاسة
          </div>
        </div>
      </div>
    </section>

    <!-- Language support -->
    <section>
      <h2 class="sec-label">Language Support</h2>
      <div class="sec-body">
        <p class="languages">{languages}</p>
      </div>
    </section>

    <!-- Glyphs -->
    <section id="glyphs">
      <h2 class="sec-label">Glyphs</h2>
      <div class="sec-body">
        <div class="glyph-controls">
          <button class="glyph-weight mono-label active" data-wght="400">Regular 400</button>
          <button class="glyph-weight mono-label" data-wght="700">Bold 700</button>
        </div>
        {
          glyphData.groups.map((group) => (
            <div class="glyph-group">
              <h3 class="mono-label">{group.name} · {group.glyphs.length}</h3>
              <div class="glyph-grid">
                {group.glyphs.map((g) => (
                  <span class="glyph-cell" title={`U+${g.u}`}>{g.c}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Download -->
    <section id="download">
      <h2 class="sec-label">Download</h2>
      <div class="sec-body">
        <p class="download-copy">
          Virtua Grotesk is free and open source under the
          <a href="https://openfontlicense.org">SIL Open Font License 1.1</a> —
          use it, ship it, modify it. Sources are UFO + designspace; builds are
          reproducible with the repo's Makefile. A Google Fonts release is in
          preparation.
        </p>
        <a class="nav-button big" href="https://github.com/eliheuer/virtua-grotesk">
          Download from GitHub
        </a>
      </div>
    </section>

    <footer>
      <span>© 2026 Eli Heuer · SIL OFL 1.1</span>
      <span>
        <a href="/blog/virtua-grotesk">Grid System as Dataset</a> ·
        <a href="/">elih.net</a> ·
        <a href="#top">Back to top ↑</a>
      </span>
    </footer>

    <style>
      /* Palette: dark gray ground, light gray ink, mark-red accent.
         Never pure black or white. */
      :root {
        --bg: #191919;
        --ink: #c9c9c9;
        --bright: #e8e8e4;
        --muted: #8a8a86;
        --rule: #3c3c3c;
        --red: #ff4a3d;
      }

      @font-face {
        font-family: 'Virtua Grotesk';
        src: url('/fonts/VirtuaGroteskVF.woff2') format('woff2-variations');
        font-weight: 400 700;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist Mono';
        src: url('/fonts/GeistMonoVF.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-display: swap;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Virtua Grotesk', sans-serif;
        font-size: 17px;
        line-height: 1.55;
      }
      a {
        color: var(--red);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .mono-label {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }

      /* ── Nav ── */
      nav {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 14px 24px;
        background: color-mix(in oklab, var(--bg) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--rule);
        font-size: 15px;
      }
      .nav-title {
        font-weight: 400;
        color: var(--bright);
      }
      .nav-links {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .nav-links a {
        color: var(--ink);
      }
      .nav-links a:hover {
        color: var(--red);
        text-decoration: none;
      }
      .nav-button {
        border: 1px solid var(--red);
        color: var(--red) !important;
        padding: 6px 14px;
        border-radius: 999px;
      }
      .nav-button:hover {
        background: var(--red);
        color: var(--bg) !important;
        text-decoration: none;
      }
      .nav-button.big {
        display: inline-block;
        font-size: 17px;
        padding: 10px 22px;
        margin-top: 1.5rem;
      }

      /* ── Hero ── */
      .hero img {
        display: block;
        width: 100%;
        height: auto;
      }

      /* ── Sections ── */
      section {
        border-top: 1px solid var(--rule);
        padding: 48px 24px 64px;
      }
      .sec-label {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-weight: 400;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 2.5rem;
      }
      .sec-body {
        max-width: 1200px;
      }

      /* Information */
      #information .sec-body {
        display: grid;
        grid-template-columns: minmax(0, 60ch) minmax(280px, 480px);
        gap: 4rem;
        max-width: none;
      }
      @media (max-width: 900px) {
        #information .sec-body {
          grid-template-columns: 1fr;
        }
      }
      .prose p {
        margin-bottom: 1.25em;
      }
      .details {
        font-size: 15px;
      }
      .detail-row {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 1rem;
        padding: 9px 0;
        border-bottom: 1px solid var(--rule);
      }
      .detail-row dt {
        color: var(--muted);
      }
      .detail-row dd {
        color: var(--bright);
      }

      /* Tables */
      .mono-table {
        border-collapse: collapse;
        font-family: 'Geist Mono', monospace;
        font-size: 13px;
        width: 100%;
        max-width: 640px;
      }
      .mono-table th {
        text-align: left;
        font-weight: 400;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 11px;
      }
      .mono-table th,
      .mono-table td {
        border-bottom: 1px solid var(--rule);
        padding: 8px 24px 8px 0;
      }
      .mono-table td {
        color: var(--bright);
      }

      /* Styles section */
      .style-row {
        border-bottom: 1px solid var(--rule);
        padding: 20px 0 28px;
      }
      .style-row:last-child {
        border-bottom: none;
      }
      .style-meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 0.75rem;
      }
      .style-sample {
        color: var(--bright);
        line-height: 1.12;
        outline: none;
        overflow-wrap: anywhere;
      }
      input[type='range'] {
        accent-color: var(--red);
        width: 180px;
        opacity: 0.35;
        transition: opacity 120ms;
      }
      .style-row:hover input[type='range'],
      input[type='range']:focus,
      #wght-slider {
        opacity: 1;
      }

      /* Weight tester */
      .tester-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }
      #wght-slider {
        width: min(420px, 60vw);
      }
      #tester-text {
        font-size: clamp(40px, 7vw, 110px);
        line-height: 1.1;
        color: var(--bright);
        font-weight: 400;
        outline: none;
        overflow-wrap: anywhere;
      }

      /* Features */
      .feature-row {
        display: grid;
        grid-template-columns: minmax(240px, 380px) 1fr;
        gap: 3rem;
        padding: 28px 0;
        border-bottom: 1px solid var(--rule);
      }
      .feature-row:last-child {
        border-bottom: none;
      }
      @media (max-width: 800px) {
        .feature-row {
          grid-template-columns: 1fr;
        }
      }
      .feature-meta p {
        font-size: 15px;
        color: var(--ink);
        margin: 0.6rem 0 1rem;
      }
      .toggle {
        cursor: pointer;
        user-select: none;
      }
      .toggle input {
        accent-color: var(--red);
        margin-right: 6px;
      }
      .feature-demo {
        font-size: clamp(32px, 4.5vw, 56px);
        line-height: 1.3;
        color: var(--bright);
      }
      #tnum-demo {
        font-feature-settings: normal;
      }
      #tnum-demo.tnum {
        font-feature-settings: 'tnum' 1;
      }

      /* Languages */
      .languages {
        max-width: 75ch;
        color: var(--ink);
      }

      /* Glyphs */
      .glyph-controls {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 2rem;
      }
      .glyph-weight {
        background: none;
        border: 1px solid var(--rule);
        border-radius: 999px;
        padding: 6px 14px;
        cursor: pointer;
      }
      .glyph-weight.active {
        border-color: var(--red);
        color: var(--red);
      }
      .glyph-group {
        margin-bottom: 2.5rem;
      }
      .glyph-group h3 {
        margin-bottom: 0.75rem;
        font-weight: 400;
      }
      .glyph-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(56px, 1fr));
        border-top: 1px solid var(--rule);
        border-left: 1px solid var(--rule);
      }
      .glyph-cell {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        color: var(--bright);
        border-right: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
        font-weight: 400;
        cursor: default;
      }
      .glyph-cell:hover {
        background: var(--rule);
        color: var(--red);
      }
      .glyphs-bold .glyph-cell {
        font-weight: 700;
      }

      /* Download / footer */
      .download-copy {
        max-width: 65ch;
      }
      footer {
        border-top: 1px solid var(--rule);
        padding: 20px 24px 28px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 14px;
        color: var(--muted);
      }
    </style>

    <script>
      // Per-style size sliders
      document.querySelectorAll<HTMLElement>('.style-row').forEach((row) => {
        const slider = row.querySelector<HTMLInputElement>('.size-slider')
        const sample = row.querySelector<HTMLElement>('.style-sample')
        if (!slider || !sample) return
        slider.addEventListener('input', () => {
          sample.style.fontSize = `${slider.value}px`
        })
      })

      // Variable weight tester
      const wghtSlider = document.getElementById('wght-slider') as HTMLInputElement | null
      const wghtValue = document.getElementById('wght-value')
      const testerText = document.getElementById('tester-text')
      if (wghtSlider && wghtValue && testerText) {
        wghtSlider.addEventListener('input', () => {
          testerText.style.fontWeight = wghtSlider.value
          wghtValue.textContent = wghtSlider.value
        })
      }

      // tnum toggle
      const tnumToggle = document.getElementById('tnum-toggle') as HTMLInputElement | null
      const tnumDemo = document.getElementById('tnum-demo')
      if (tnumToggle && tnumDemo) {
        tnumToggle.addEventListener('change', () => {
          tnumDemo.classList.toggle('tnum', tnumToggle.checked)
        })
      }

      // Glyph grid weight toggle
      const glyphsSection = document.getElementById('glyphs')
      document.querySelectorAll<HTMLButtonElement>('.glyph-weight').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.glyph-weight')
            .forEach((b) => b.classList.toggle('active', b === btn))
          glyphsSection?.classList.toggle('glyphs-bold', btn.dataset.wght === '700')
        })
      })
    </script>
  </body>
</html>
