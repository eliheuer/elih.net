---
// Standalone specimen page for Hasubi Mono — same full-page treatment as
// /virtua-grotesk, deliberately outside the site Layout.
import glyphData from '@/data/hasubi-mono-glyphs.json'

const details: [string, string][] = [
  ['Design', 'Eli Heuer'],
  ['Released', '2022 · alpha, in development'],
  ['Version', '1.0'],
  ['Classification', 'Monospace · horizontal contrast'],
  ['Glyphs', '623'],
  ['Styles', '1 · Regular'],
  ['Formats', 'TTF · WOFF2'],
  ['Scripts', 'Latin · Hebrew · Arabic (in progress)'],
  ['License', 'SIL Open Font License 1.1'],
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hasubi Mono</title>
    <meta
      name="description"
      content="Hasubi Mono — a monospace typeface with horizontal contrast, flipping the usual vertical stress. Latin, Hebrew and Arabic. Free and open source under the SIL Open Font License 1.1."
    />
    <link rel="canonical" href="https://elih.net/hasubi-mono" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <meta property="og:title" content="Hasubi Mono" />
    <meta
      property="og:description"
      content="A monospace typeface with horizontal contrast, flipping the usual vertical stress. Free and open source."
    />
    <meta property="og:url" content="https://elih.net/hasubi-mono" />
  </head>

  <body>
    <nav id="top">
      <span class="nav-title">Hasubi Mono</span>
      <div class="nav-links">
        <a href="#information">Information</a>
        <a href="#styles">Styles</a>
        <a href="#tester">Tester</a>
        <a href="#glyphs">Glyphs</a>
        <a class="nav-button" href="https://github.com/eliheuer/hasubi-mono">Download fonts</a>
      </div>
    </nav>

    <!-- Hero -->
    <header class="hero-text" contenteditable="true" spellcheck="false">
      Hasubi Mono
    </header>

    <!-- Information -->
    <section id="information">
      <h2 class="sec-label">Information</h2>
      <div class="sec-body">
        <div class="prose">
          <p>
            Hasubi Mono is a monospace typeface with horizontal contrast: the
            usual stress pattern is flipped, so horizontal strokes carry the
            weight and verticals stay thin. The reversed contrast gives code
            and terminal text a distinctive rhythm without giving up the
            fixed-pitch grid.
          </p>
          <p>
            It is an alpha-quality, pre-1.0 typeface under active development.
            Latin coverage is broad; Hebrew and Arabic are in progress.
            Sources are open on
            <a href="https://github.com/eliheuer/hasubi-mono">GitHub</a>.
          </p>
        </div>

        <dl class="details">
          {
            details.map(([k, v]) => (
              <div class="detail-row">
                <dt>{k}</dt>
                <dd>{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- Files -->
    <section>
      <h2 class="sec-label">Files</h2>
      <div class="sec-body">
        <table class="mono-table">
          <thead>
            <tr><th>Font</th><th>Format</th><th>Web file size</th></tr>
          </thead>
          <tbody>
            <tr><td>Hasubi Mono Regular</td><td>WOFF2</td><td>26 kb</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Styles -->
    <section id="styles">
      <h2 class="sec-label">Styles</h2>
      <div class="style-list">
        <div class="style-row">
          <div class="style-meta">
            <span class="mono-label">Regular · 400</span>
            <input
              type="range"
              class="size-slider"
              min="24"
              max="160"
              value="72"
              aria-label="Sample size for Regular"
            />
          </div>
          <div
            class="style-sample"
            contenteditable="true"
            spellcheck="false"
            style="font-weight: 400; font-size: 72px;"
          >
            Hasubi Mono Regular
          </div>
        </div>
      </div>
    </section>

    <!-- Tester -->
    <section id="tester">
      <h2 class="sec-label">Tester</h2>
      <div class="sec-body">
        <div id="tester-text" contenteditable="true" spellcheck="false">
          fn main() &#123; println!("horizontal contrast"); &#125;
        </div>
      </div>
    </section>

    <!-- Multi-script -->
    <section id="features">
      <h2 class="sec-label">Scripts</h2>
      <div class="sec-body">
        <div class="feature-row">
          <div class="feature-meta">
            <span class="mono-label">Latin</span>
            <p>Broad European Latin coverage on a strict fixed-pitch grid,
            hinted with ttfautohint for small sizes on screen.</p>
          </div>
          <div class="feature-demo">
            AaBbCc 0123456789<br />&#123;&#125;[]()=&gt;!=&lt;-&gt;
          </div>
        </div>

        <div class="feature-row">
          <div class="feature-meta">
            <span class="mono-label">Hebrew · Arabic</span>
            <p>Hebrew and Arabic extensions are drawn to the same reversed
            contrast logic. Both are in progress at alpha quality.</p>
          </div>
          <div class="feature-demo" dir="rtl">
            עברית · <span lang="ar">عربي</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Glyphs -->
    <section id="glyphs">
      <h2 class="sec-label">Glyphs</h2>
      <div class="sec-body">
        {
          glyphData.groups.map((group) => (
            <div class="glyph-group">
              <h3 class="mono-label">{group.name} · {group.glyphs.length}</h3>
              <div class="glyph-grid">
                {group.glyphs.map((g) => (
                  <span class="glyph-cell" title={`U+${g.u}`}>{g.c}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Download -->
    <section id="download">
      <h2 class="sec-label">Download</h2>
      <div class="sec-body">
        <p class="download-copy">
          Hasubi Mono is free and open source under the
          <a href="https://openfontlicense.org">SIL Open Font License 1.1</a>.
          It is alpha software: expect missing glyphs and changing metrics
          between versions.
        </p>
        <a class="nav-button big" href="https://github.com/eliheuer/hasubi-mono">
          Download from GitHub
        </a>
      </div>
    </section>

    <footer>
      <span>© 2026 Eli Heuer · SIL OFL 1.1</span>
      <span>
        <a href="/fonts/hasubi-mono">Notes</a> ·
        <a href="/">elih.net</a> ·
        <a href="#top">Back to top ↑</a>
      </span>
    </footer>

    <style>
      :root {
        --bg: #191919;
        --ink: #c9c9c9;
        --bright: #e8e8e4;
        --muted: #8a8a86;
        --rule: #3c3c3c;
        --red: #ff4a3d;
      }

      @font-face {
        font-family: 'Hasubi Mono';
        src: url('/fonts/HasubiMono-Regular.woff2') format('woff2');
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist Mono';
        src: url('/fonts/GeistMonoVF.woff2') format('woff2-variations');
        font-weight: 100 900;
        font-display: swap;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'Hasubi Mono', monospace;
        font-size: 16px;
        line-height: 1.6;
      }
      a {
        color: var(--red);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .mono-label {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }

      nav {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 14px 24px;
        background: color-mix(in oklab, var(--bg) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--rule);
        font-size: 15px;
      }
      .nav-title {
        font-weight: 400;
        color: var(--bright);
      }
      .nav-links {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .nav-links a {
        color: var(--ink);
      }
      .nav-links a:hover {
        color: var(--red);
        text-decoration: none;
      }
      .nav-button {
        border: 1px solid var(--red);
        color: var(--red) !important;
        padding: 6px 14px;
        border-radius: 999px;
      }
      .nav-button:hover {
        background: var(--red);
        color: var(--bg) !important;
        text-decoration: none;
      }
      .nav-button.big {
        display: inline-block;
        font-size: 16px;
        padding: 10px 22px;
        margin-top: 1.5rem;
      }

      .hero-text {
        padding: 10vh 24px;
        font-size: clamp(48px, 11vw, 180px);
        line-height: 1.05;
        color: var(--bright);
        outline: none;
        overflow-wrap: anywhere;
      }

      section {
        border-top: 1px solid var(--rule);
        padding: 48px 24px 64px;
      }
      .sec-label {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-weight: 400;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 2.5rem;
      }
      .sec-body {
        max-width: 1200px;
      }

      #information .sec-body {
        display: grid;
        grid-template-columns: minmax(0, 60ch) minmax(280px, 480px);
        gap: 4rem;
        max-width: none;
      }
      @media (max-width: 900px) {
        #information .sec-body {
          grid-template-columns: 1fr;
        }
      }
      .prose p {
        margin-bottom: 1.25em;
      }
      .details {
        font-size: 14px;
      }
      .detail-row {
        display: grid;
        grid-template-columns: 150px 1fr;
        gap: 1rem;
        padding: 9px 0;
        border-bottom: 1px solid var(--rule);
      }
      .detail-row dt {
        color: var(--muted);
      }
      .detail-row dd {
        color: var(--bright);
      }

      .mono-table {
        border-collapse: collapse;
        font-family: 'Geist Mono', monospace;
        font-size: 13px;
        width: 100%;
        max-width: 640px;
      }
      .mono-table th {
        text-align: left;
        font-weight: 400;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 11px;
      }
      .mono-table th,
      .mono-table td {
        border-bottom: 1px solid var(--rule);
        padding: 8px 24px 8px 0;
      }
      .mono-table td {
        color: var(--bright);
      }

      .style-row {
        border-bottom: 1px solid var(--rule);
        padding: 20px 0 28px;
      }
      .style-row:last-child {
        border-bottom: none;
      }
      .style-meta {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 0.75rem;
      }
      .style-sample {
        color: var(--bright);
        line-height: 1.12;
        outline: none;
        overflow-wrap: anywhere;
      }
      input[type='range'] {
        accent-color: var(--red);
        width: 180px;
        opacity: 0.35;
        transition: opacity 120ms;
      }
      .style-row:hover input[type='range'],
      input[type='range']:focus {
        opacity: 1;
      }

      #tester-text {
        font-size: clamp(28px, 5vw, 72px);
        line-height: 1.25;
        color: var(--bright);
        outline: none;
        overflow-wrap: anywhere;
      }

      .feature-row {
        display: grid;
        grid-template-columns: minmax(240px, 380px) 1fr;
        gap: 3rem;
        padding: 28px 0;
        border-bottom: 1px solid var(--rule);
      }
      .feature-row:last-child {
        border-bottom: none;
      }
      @media (max-width: 800px) {
        .feature-row {
          grid-template-columns: 1fr;
        }
      }
      .feature-meta p {
        font-size: 14px;
        color: var(--ink);
        margin: 0.6rem 0 1rem;
      }
      .feature-demo {
        font-size: clamp(28px, 4vw, 48px);
        line-height: 1.4;
        color: var(--bright);
      }

      .glyph-group {
        margin-bottom: 2.5rem;
      }
      .glyph-group h3 {
        margin-bottom: 0.75rem;
        font-weight: 400;
      }
      .glyph-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(56px, 1fr));
        border-top: 1px solid var(--rule);
        border-left: 1px solid var(--rule);
      }
      .glyph-cell {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: var(--bright);
        border-right: 1px solid var(--rule);
        border-bottom: 1px solid var(--rule);
        cursor: default;
      }
      .glyph-cell:hover {
        background: var(--rule);
        color: var(--red);
      }

      .download-copy {
        max-width: 65ch;
      }
      footer {
        border-top: 1px solid var(--rule);
        padding: 20px 24px 28px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 13px;
        color: var(--muted);
      }
    </style>

    <script>
      // Per-style size sliders
      document.querySelectorAll<HTMLElement>('.style-row').forEach((row) => {
        const slider = row.querySelector<HTMLInputElement>('.size-slider')
        const sample = row.querySelector<HTMLElement>('.style-sample')
        if (!slider || !sample) return
        slider.addEventListener('input', () => {
          sample.style.fontSize = `${slider.value}px`
        })
      })
    </script>
  </body>
</html>
