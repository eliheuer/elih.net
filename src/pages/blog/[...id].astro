---
import Link from '@/components/Link.astro'
import PostHead from '@/components/PostHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAdjacentPosts, getAllPosts } from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getAllPosts()

  return posts.map((post) => ({
    params: { id: post.id },
    props: post,
  }))
}

const post = Astro.props
const currentPostId = Astro.params.id
const { Content } = await render(post)
const { next, prev } = await getAdjacentPosts(currentPostId)

// Break the display title after its first colon (main: subtitle) so long
// titles wrap on the colon instead of mid-phrase. Meta title stays untouched.
const [titleMain, titleRest] = post.data.title.split(/:\s+(.*)/s)
---

<Layout>
  <PostHead slot="head" post={post} />

  <article class="pt-5 pb-8">
    <header class="mb-4">
      <h1 class={`text-[2.25rem] sm:text-[2.6667rem] ${currentPostId === 'virtua-grotesk' ? 'leading-[0.95]' : 'leading-[1.05]'} tracking-[-0.02em] text-balance font-semibold`}>{titleRest ? (<>{titleMain}:<br />{titleRest}</>) : post.data.title}</h1>
      <p class="text-muted-foreground -mt-0.5">
        <time datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        {post.data.dateNote && <span> · {post.data.dateNote}</span>}
      </p>
    </header>

    <div class={`prose ${currentPostId === 'virtua-grotesk' ? 'tight-headings' : ''}`}>
      <Content />
    </div>
  </article>

  {
    (prev || next) && (
      <nav class="border-foreground text-muted-foreground flex justify-between gap-x-6 border-t py-6">
        <span>
          {prev && (
            <Link href={`/blog/${prev.id}`} class="hover:text-foreground">
              &larr; {prev.data.title}
            </Link>
          )}
        </span>
        <span class="text-right">
          {next && (
            <Link href={`/blog/${next.id}`} class="hover:text-foreground">
              {next.data.title} &rarr;
            </Link>
          )}
        </span>
      </nav>
    )
  }
</Layout>
